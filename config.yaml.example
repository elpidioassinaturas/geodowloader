# ─── Earthdata (NISAR, SRTM, Landsat) ─────────────────────────────────────────
earthdata:
  username: ""
  password: ""

# ─── Copernicus CDSE (Sentinel-1, Sentinel-2, CopDEM) ─────────────────────────
copernicus:
  email:    ""
  password: ""

# ─── CDS API (ERA5) ────────────────────────────────────────────────────────────
# Crie conta em: https://cds.climate.copernicus.eu
# Após login: clique no seu perfil → API key
cds:
  url: "https://cds.climate.copernicus.eu/api"
  key: ""

# ─── Download ──────────────────────────────────────────────────────────────────
download:
  directory: downloads
  processes: 2
